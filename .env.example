# URL del servicio backend al que el formulario de captura envía los datos.
PUBLIC_API_URL=https://api.ejemplo.com/leads

# API key del servicio backend.
# ADVERTENCIA: al llevar el prefijo PUBLIC_, Astro expone este valor en el
# bundle de JavaScript que se sirve al navegador. No es un secreto oculto.
PUBLIC_API_KEY=

# Identificador de la plataforma/proyecto que se envía en cada petición.
PUBLIC_PLATFORM_NAME=
