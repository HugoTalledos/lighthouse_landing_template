---
import '../styles/global.css';

interface Theme {
  primaryColor: string;
  secondaryColor: string;
  fontFamily: string;
}

interface Props {
  title?: string;
  theme?: Theme;
}

const { title = 'Landing Page Template', theme }: Props = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {theme && (
      <style set:html={`:root { --color-primary: ${theme.primaryColor}; --color-secondary: ${theme.secondaryColor}; --font-sans: '${theme.fontFamily}', system-ui, sans-serif; }`} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
