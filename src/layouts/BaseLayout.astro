---
import '../styles/global.css';

interface Theme {
  primaryColor?: string;
  primaryForegroundColor?: string;
  secondaryColor?: string;
  bgColor?: string;
  bgMutedColor?: string;
  textColor?: string;
  textMutedColor?: string;
  fontFamily?: string;
}

interface Props {
  title?: string;
  theme?: Theme;
}

const { title = 'Landing Page Template', theme }: Props = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {theme && (
      <style set:html={`:root {
        ${theme.primaryColor ? `--color-primary: ${theme.primaryColor};` : ''}
        ${theme.primaryForegroundColor ? `--color-primary-foreground: ${theme.primaryForegroundColor};` : ''}
        ${theme.secondaryColor ? `--color-secondary: ${theme.secondaryColor};` : ''}
        ${theme.bgColor ? `--color-bg: ${theme.bgColor};` : ''}
        ${theme.bgMutedColor ? `--color-bg-muted: ${theme.bgMutedColor};` : ''}
        ${theme.textColor ? `--color-text: ${theme.textColor};` : ''}
        ${theme.textMutedColor ? `--color-text-muted: ${theme.textMutedColor};` : ''}
        ${theme.fontFamily ? `--font-sans: '${theme.fontFamily}', system-ui, sans-serif;` : ''}
      }`} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
