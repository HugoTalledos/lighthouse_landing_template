---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../component/organisms/Hero.astro';
import BenefitsSection from '../component/organisms/BenefitsSection.astro';
import CaptureForm from '../component/organisms/CaptureForm.astro';
import PricingSection from '../component/organisms/PricingSection.astro';
import TestimonialsSection from '../component/organisms/TestimonialsSection.astro';
import FaqSection from '../component/organisms/FaqSection.astro';
import CtaSection from '../component/organisms/CtaSection.astro';
import Footer from '../component/organisms/Footer.astro';
import pageData from '../data/page.json';
import type { RawTheme } from '../../model/theme.types';
import type { HeroConfig } from '../../model/hero.types';

interface RawSection {
  type: string;
  [key: string]: unknown;
}

interface PageData {
  theme: RawTheme;
  sections: RawSection[];
}

const data = pageData as PageData;

const HEX_COLOR_RE = /^#[0-9a-fA-F]{3,8}$/;
const SAFE_FONT_RE = /^[A-Za-z0-9 _-]+$/;

function sanitizeTheme(theme: RawTheme) {
  if (!HEX_COLOR_RE.test(theme.primary_color)) {
    throw new Error(`page.json: theme.primary_color is not a valid hex color: ${JSON.stringify(theme.primary_color)}`);
  }
  if (!HEX_COLOR_RE.test(theme.secondary_color)) {
    throw new Error(`page.json: theme.secondary_color is not a valid hex color: ${JSON.stringify(theme.secondary_color)}`);
  }
  if (!SAFE_FONT_RE.test(theme.font_family)) {
    throw new Error(`page.json: theme.font_family contains invalid characters: ${JSON.stringify(theme.font_family)}`);
  }
  if (theme.bg_color != null && !HEX_COLOR_RE.test(theme.bg_color)) {
    throw new Error(`page.json: theme.bg_color is not a valid hex color: ${JSON.stringify(theme.bg_color)}`);
  }
  if (theme.text_color != null && !HEX_COLOR_RE.test(theme.text_color)) {
    throw new Error(`page.json: theme.text_color is not a valid hex color: ${JSON.stringify(theme.text_color)}`);
  }
  return {
    primaryColor: theme.primary_color,
    secondaryColor: theme.secondary_color,
    fontFamily: theme.font_family,
    bgColor: theme.bg_color ?? undefined,
    textColor: theme.text_color ?? undefined,
  };
}

const heroSection = data.sections.find((s) => s.type === 'hero') as | Omit<HeroConfig, 'logo'> | undefined;

const featuresSection = data.sections.find((s) => s.type === 'features') as
  | { headline?: string; headline_highlight?: string | null; items: { title: string; description: string; icon?: string | null }[] }
  | undefined;

const pricingSection = data.sections.find((s) => s.type === 'pricing') as
  | { headline?: string; plans: { name: string; price: string; period?: string | null; features: string[]; cta_text: string }[] }
  | undefined;

const testimonialsSection = data.sections.find((s) => s.type === 'testimonials') as
  | { headline?: string; items: { quote: string; author_name: string; author_role?: string | null }[] }
  | undefined;

const faqSection = data.sections.find((s) => s.type === 'faq') as
  | { headline?: string; items: { question: string; answer: string }[] }
  | undefined;

const ctaSection = data.sections.find((s) => s.type === 'cta') as
  | { headline: string; subheadline?: string | null; button_text: string; button_url?: string | null }
  | undefined;

const footerSection = data.sections.find((s) => s.type === 'footer') as
  | { business_name: string; links: { label: string; url: string }[]; social_links?: { platform: string; url: string }[] }
  | undefined;

const captureSection = data.sections.find((s) => s.type === 'capture') as
  | { headline?: string; subheadline?: string; cta_text?: string }
  | undefined;

const theme = sanitizeTheme(data.theme);

const fallbackItems: { title: string; description: string; icon?: string | null }[] = [
  { title: 'Beneficio uno', description: 'Descripción breve del primer beneficio ofrecido.' },
  { title: 'Beneficio dos', description: 'Descripción breve del segundo beneficio ofrecido.' },
  { title: 'Beneficio tres', description: 'Descripción breve del tercer beneficio ofrecido.' },
];
---

<BaseLayout title="Landing Page Template" theme={theme}>
  <Hero
    layout={heroSection?.layout ?? 'side'}
    text={{
      headline: heroSection?.text.headline ?? 'Título principal de tu producto o servicio',
      headline_highlight: heroSection?.text.headline_highlight ?? undefined,
      subheadline: heroSection?.text.subheadline ?? 'Subtítulo de apoyo que explica en una frase el valor de lo que ofreces.',
      cta_text: heroSection?.text.cta_text ?? 'Comenzar ahora',
      align: heroSection?.text.align ?? 'center',
    }}
    image={{
      url: heroSection?.image.url ?? undefined,
      blur: heroSection?.image.blur ?? false,
      overlay_opacity: heroSection?.image.overlay_opacity ?? 0.55,
      position: heroSection?.image.position ?? 'right',
      shape: heroSection?.image.shape ?? 'rounded',
    }}
    logo={{
      logoText: data.theme.logo_text ?? undefined,
      logoIcon: data.theme.logo_icon ?? undefined,
      logoUrl: data.theme.logo_url ?? undefined,
    }}
  />
  <BenefitsSection
    heading={featuresSection?.headline ?? 'Beneficios'}
    headingHighlight={featuresSection?.headline_highlight ?? undefined}
    headingAlign="center"
    cardAlign="left"
    iconPosition='center'
    items={(featuresSection?.items ?? fallbackItems).map(({ title, description, icon }) => ({ title, description, icon: icon ?? undefined }))}
  />
  {pricingSection && (
    <PricingSection
      heading={pricingSection.headline ?? 'Planes'}
      headingAlign="center"
      plans={pricingSection.plans.map((plan) => ({
        name: plan.name,
        price: plan.price,
        period: plan.period ?? undefined,
        features: plan.features,
        ctaLabel: plan.cta_text,
      }))}
    />
  )}
  {testimonialsSection && (
    <TestimonialsSection
      heading={testimonialsSection.headline ?? 'Lo que dicen nuestros clientes'}
      headingAlign="center"
      items={testimonialsSection.items.map((item) => ({
        quote: item.quote,
        authorName: item.author_name,
        authorRole: item.author_role ?? undefined,
      }))}
    />
  )}
  {faqSection && (
    <FaqSection heading={faqSection.headline ?? 'Preguntas frecuentes'} headingAlign="center" items={faqSection.items} />
  )}
  {ctaSection && (
    <CtaSection
      headline={ctaSection.headline}
      subheadline={ctaSection.subheadline ?? undefined}
      buttonLabel={ctaSection.button_text}
      buttonHref={ctaSection.button_url ?? undefined}
      align="center"
    />
  )}
  <CaptureForm
    heading={captureSection?.headline ?? 'Déjanos tus datos'}
    subtitle={captureSection?.subheadline ?? 'Te contactaremos con más información.'}
    align="center"
    ctaLabel={captureSection?.cta_text ?? 'Enviar'}
  />
  {footerSection && (
    <Footer
      businessName={footerSection.business_name}
      links={footerSection.links}
      socialLinks={footerSection.social_links}
    />
  )}
</BaseLayout>
