---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../component/organisms/Hero.astro';
import BenefitsSection from '../component/organisms/BenefitsSection.astro';
import CaptureForm from '../component/organisms/CaptureForm.astro';
import PricingSection from '../component/organisms/PricingSection.astro';
import TestimonialsSection from '../component/organisms/TestimonialsSection.astro';
import FaqSection from '../component/organisms/FaqSection.astro';
import CtaSection from '../component/organisms/CtaSection.astro';
import Footer from '../component/organisms/Footer.astro';
import pageData from '../data/page.json';

interface RawSection {
  type: string;
  [key: string]: unknown;
}

interface RawTheme {
  primary_color: string;
  secondary_color: string;
  font_family: string;
  logo_text?: string | null;
  logo_icon?: string | null;
}

interface PageData {
  theme: RawTheme;
  sections: RawSection[];
}

const data = pageData as PageData;

const HEX_COLOR_RE = /^#[0-9a-fA-F]{3,8}$/;
const SAFE_FONT_RE = /^[A-Za-z0-9 _-]+$/;

function sanitizeTheme(theme: RawTheme) {
  return {
    primaryColor: HEX_COLOR_RE.test(theme.primary_color) ? theme.primary_color : '#4f46e5',
    secondaryColor: HEX_COLOR_RE.test(theme.secondary_color) ? theme.secondary_color : '#0ea5e9',
    fontFamily: SAFE_FONT_RE.test(theme.font_family) ? theme.font_family : 'Inter',
  };
}

const heroSection = data.sections.find((s) => s.type === 'hero') as
  | { headline: string; subheadline: string; cta_text: string }
  | undefined;

const featuresSection = data.sections.find((s) => s.type === 'features') as
  | { headline?: string; items: { title: string; description: string }[] }
  | undefined;

const pricingSection = data.sections.find((s) => s.type === 'pricing') as
  | { plans: { name: string; price: string; period?: string | null; features: string[]; cta_text: string }[] }
  | undefined;

const testimonialsSection = data.sections.find((s) => s.type === 'testimonials') as
  | { items: { quote: string; author_name: string; author_role?: string | null }[] }
  | undefined;

const faqSection = data.sections.find((s) => s.type === 'faq') as
  | { items: { question: string; answer: string }[] }
  | undefined;

const ctaSection = data.sections.find((s) => s.type === 'cta') as
  | { headline: string; subheadline?: string | null; button_text: string; button_url?: string | null }
  | undefined;

const footerSection = data.sections.find((s) => s.type === 'footer') as
  | { business_name: string; links: { label: string; url: string }[]; social_links?: { platform: string; url: string }[] }
  | undefined;

const theme = sanitizeTheme(data.theme);

const fallbackItems = [
  { title: 'Beneficio uno', description: 'Descripción breve del primer beneficio ofrecido.' },
  { title: 'Beneficio dos', description: 'Descripción breve del segundo beneficio ofrecido.' },
  { title: 'Beneficio tres', description: 'Descripción breve del tercer beneficio ofrecido.' },
];
---

<BaseLayout title="Landing Page Template" theme={theme}>
  <Hero
    title={heroSection?.headline ?? 'Título principal de tu producto o servicio'}
    subtitle={heroSection?.subheadline ?? 'Subtítulo de apoyo que explica en una frase el valor de lo que ofreces.'}
    ctaLabel={heroSection?.cta_text ?? 'Comenzar ahora'}
    align="left"
    textPosition="left"
    logoText={data.theme.logo_text ?? undefined}
    logoIcon={data.theme.logo_icon ?? undefined}
  />
  <BenefitsSection
    heading={featuresSection?.headline ?? 'Beneficios'}
    headingAlign="center"
    cardAlign="left"
    items={(featuresSection?.items ?? fallbackItems).map(({ title, description }) => ({ title, description }))}
  />
  {pricingSection && (
    <PricingSection
      heading="Planes"
      headingAlign="center"
      plans={pricingSection.plans.map((plan) => ({
        name: plan.name,
        price: plan.price,
        period: plan.period ?? undefined,
        features: plan.features,
        ctaLabel: plan.cta_text,
      }))}
    />
  )}
  {testimonialsSection && (
    <TestimonialsSection
      heading="Lo que dicen nuestros clientes"
      headingAlign="center"
      items={testimonialsSection.items.map((item) => ({
        quote: item.quote,
        authorName: item.author_name,
        authorRole: item.author_role ?? undefined,
      }))}
    />
  )}
  {faqSection && (
    <FaqSection heading="Preguntas frecuentes" headingAlign="center" items={faqSection.items} />
  )}
  {ctaSection && (
    <CtaSection
      headline={ctaSection.headline}
      subheadline={ctaSection.subheadline ?? undefined}
      buttonLabel={ctaSection.button_text}
      buttonHref={ctaSection.button_url ?? undefined}
      align="center"
    />
  )}
  <CaptureForm
    heading="Déjanos tus datos"
    subtitle="Te contactaremos con más información."
    align="center"
    ctaLabel="Enviar"
  />
  {footerSection && (
    <Footer
      businessName={footerSection.business_name}
      links={footerSection.links}
      socialLinks={footerSection.social_links}
    />
  )}
</BaseLayout>
