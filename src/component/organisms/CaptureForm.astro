---
import Container from '../atoms/Container.astro';
import Heading from '../atoms/Heading.astro';
import Text from '../atoms/Text.astro';
import Button from '../atoms/Button.astro';
import FormField from '../molecules/FormField.astro';
import { splitHighlight } from '../../utils/highlightText';

interface Props {
  heading: string;
  headingHighlight?: string | null;
  subtitle: string;
  align: 'left' | 'center';
  ctaLabel: string;
  background?: 'primary' | 'secondary';
}

const { heading, headingHighlight, subtitle, align, ctaLabel, background = 'primary' }: Props = Astro.props;

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
};

const headingParts = splitHighlight(heading, headingHighlight);
const sectionBgClass = background === 'secondary' ? 'bg-[var(--color-bg-secondary)]' : '';
---

<section class={`py-16 md:py-24 ${sectionBgClass}`} id="formulario-captura">
  <Container class="mx-auto flex max-w-xl flex-col gap-6">
    <div class={`flex flex-col gap-2 ${alignClasses[align]}`}>
      <Heading as="h2" size="md" align={align}>
        {headingParts.map((part) =>
          part.highlighted ? <span class="text-[var(--color-secondary)]">{part.text}</span> : part.text
        )}
      </Heading>
      <Text muted>{subtitle}</Text>
    </div>
    <form id="capture-form" class="flex flex-col gap-4" novalidate>
      <FormField label="Nombre" name="nombre" placeholder="Tu nombre" required />
      <FormField label="Correo electrónico" name="email" type="email" placeholder="tu@correo.com" required />
      <FormField label="Número de celular" name="celular" type="tel" placeholder="3001234567" required />
      <Button type="submit" variant="primary">{ctaLabel}</Button>
      <p id="capture-form-success" class="hidden text-center text-sm text-green-600">
        ¡Gracias! Hemos recibido tu información.
      </p>
      <p id="capture-form-error" class="hidden text-center text-sm text-red-600">
        Ocurrió un error al enviar tu información. Intenta de nuevo.
      </p>
    </form>
  </Container>
</section>

<script>
  import './CaptureForm.client.ts';
</script>
