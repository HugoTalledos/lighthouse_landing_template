---
import Container from '../atoms/Container.astro';
import Link from '../atoms/Link.astro';

interface FooterLink {
  label: string;
  url: string;
}

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  businessName: string;
  links: FooterLink[];
  socialLinks?: SocialLink[];
  background?: 'primary' | 'secondary';
}

const { businessName, links, socialLinks, background = 'primary' }: Props = Astro.props;

const sectionBgClass = background === 'secondary' ? 'bg-[var(--color-bg-secondary)]' : '';
---

<footer class={`border-t border-gray-200 py-10 ${sectionBgClass}`}>
  <Container class="flex flex-col items-center gap-4 md:flex-row md:justify-between">
    <span class="font-semibold text-[var(--color-text)]">{businessName}</span>
    <nav class="flex gap-4">
      {links.map((link) => (
        <Link href={link.url}>{link.label}</Link>
      ))}
    </nav>
    {socialLinks && socialLinks.length > 0 && (
      <nav class="flex gap-4">
        {socialLinks.map((social) => (
          <Link href={social.url}>{social.platform}</Link>
        ))}
      </nav>
    )}
  </Container>
</footer>
