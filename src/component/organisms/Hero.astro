---
import type { HeroConfig } from '../../../model/hero.types';
import Container from '../atoms/Container.astro';
import Heading from '../atoms/Heading.astro';
import Text from '../atoms/Text.astro';
import Button from '../atoms/Button.astro';
import Logo from '../molecules/Logo.astro';
import { splitHighlight } from '../../utils/highlightText';

type Props = HeroConfig;

const { layout, text, image, logo }: Props = Astro.props;

const { headline: title, headline_highlight: titleHighlight, subheadline: subtitle, cta_text: ctaLabel, align } = text;
const { url: imageUrl, blur, overlay_opacity: overlayOpacity, position, shape } = image;
const { logoText, logoIcon, logoUrl } = logo;

const titleParts = splitHighlight(title, titleHighlight);

const backgroudConfig = { blur: blur ?? false, overlayOpacity: overlayOpacity ?? 0.55 };
const sideConfig = { position: position ?? 'right', shape: shape ?? 'rounded' };

const isBackground = (layout ?? 'side') === 'background' && !!imageUrl;

const alignClasses = {
  left: 'items-start text-left',
  center: 'items-center text-center',
  right: 'items-end text-right'
};

// sideConfig.position is the side the IMAGE sits on; text takes the opposite side.
const imageOrderClasses = {
  left: 'md:order-1',
  right: 'md:order-2',
};

const textOrderClasses = {
  left: 'md:order-2',
  right: 'md:order-1',
};

const shapeClasses = {
  circle: 'rounded-full',
  rounded: 'rounded-lg',
};
---

<header class="border-b border-gray-200">
  <Container class="flex items-center justify-between py-6">
    <Logo text={logoText} logoUrl={logoUrl}>
      {logoIcon && <Fragment slot="icon" set:html={logoIcon} />}
    </Logo>
  </Container>
</header>

<section
  class={
    isBackground
      ? 'relative flex min-h-[480px] items-center overflow-hidden md:min-h-[600px]'
      : 'py-16 md:py-24'
  }
>
  {
    isBackground && (
      <>
        <img
          src={imageUrl}
          alt=""
          class={`absolute inset-0 h-full w-full object-cover ${backgroudConfig.blur ? 'blur-md' : ''}`}
        />
        <div class="absolute inset-0 bg-black" style={{ opacity: backgroudConfig.overlayOpacity }} />
      </>
    )
  }
  <Container
    class={
      isBackground
        ? 'relative z-10 py-16 md:py-24'
        : 'grid grid-cols-1 items-center gap-12 md:grid-cols-2'
    }
  >
    <div
      class={`flex flex-col gap-6 ${alignClasses[align]} ${!isBackground ? textOrderClasses[sideConfig.position] : ''}`}
    >
      <Heading as="h1" size="lg" align={align} class={isBackground ? 'text-white' : ''}>
        {titleParts.map((part) =>
          part.highlighted ? <span class="text-[var(--color-secondary)]">{part.text}</span> : part.text
        )}
      </Heading>
      <Text size="lg" muted={!isBackground} class={isBackground ? 'text-white/85' : ''}>
        {subtitle}
      </Text>
      <div>
        <Button variant="primary" href="#formulario-captura">{ctaLabel}</Button>
      </div>
    </div>
    {
      !isBackground &&
      (
        imageUrl &&
        (
          <img
            src={imageUrl}
            alt=""
            class={`h-64 w-full object-cover md:h-96 ${shapeClasses[sideConfig.shape]} ${imageOrderClasses[sideConfig.position]}`}
          />
        )
      )
    }
  </Container>
</section>
