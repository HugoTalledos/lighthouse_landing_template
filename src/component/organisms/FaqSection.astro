---
import Container from '../atoms/Container.astro';
import Heading from '../atoms/Heading.astro';
import FaqItem from '../molecules/FaqItem.astro';
import { splitHighlight } from '../../utils/highlightText';

interface FaqEntry {
  question: string;
  answer: string;
}

interface Props {
  heading: string;
  headingHighlight?: string | null;
  headingAlign: 'left' | 'center';
  items: FaqEntry[];
  background?: 'primary' | 'secondary';
}

const { heading, headingHighlight, headingAlign, items, background = 'primary' }: Props = Astro.props;

const headingParts = splitHighlight(heading, headingHighlight);
const sectionBgClass = background === 'secondary' ? 'bg-[var(--color-bg-secondary)]' : '';
---

<section class={`py-16 md:py-24 ${sectionBgClass}`} id="preguntas-frecuentes">
  <Container class="mx-auto flex max-w-3xl flex-col gap-10">
    <Heading as="h2" size="md" align={headingAlign}>
      {headingParts.map((part) =>
        part.highlighted ? <span class="text-[var(--color-secondary)]">{part.text}</span> : part.text
      )}
    </Heading>
    <div class="flex flex-col gap-4">
      {items.map((item) => (
        <FaqItem question={item.question} answer={item.answer} />
      ))}
    </div>
  </Container>
</section>
