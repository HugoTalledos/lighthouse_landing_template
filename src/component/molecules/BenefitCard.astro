---
import Heading from '../atoms/Heading.astro';
import Text from '../atoms/Text.astro';

interface Props {
  title: string;
  description: string;
  align: ALIGN_CONFIG
  iconPosition?: ALIGN_CONFIG
  class?: string;
}

const { title, description, align, iconPosition, class: className }: Props = Astro.props;

const alignClasses = {
  left: 'items-start text-left',
  center: 'items-center text-center',
  right: 'items-end text-right'
};

const iconPositionClasses = {
  left: 'self-start',
  center: 'self-center',
  right: 'self-end',
};

const resolvedIconPosition = iconPositionClasses[iconPosition ?? align];
---

<div class={`group flex flex-col gap-5 rounded-2xl bg-white p-8 shadow-sm ring-1 ring-black/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:ring-[color-mix(in_srgb,var(--color-primary)_20%,transparent)] ${alignClasses[align]} ${className ?? ''}`}>
  <div class={`flex h-14 w-14 items-center justify-center rounded-2xl bg-[color-mix(in_srgb,var(--color-primary)_10%,white)] text-2xl text-[var(--color-primary)] ring-1 ring-[color-mix(in_srgb,var(--color-primary)_15%,white)] transition-transform duration-300 group-hover:scale-110 group-hover:bg-[color-mix(in_srgb,var(--color-primary)_15%,white)] ${resolvedIconPosition}`}>
    <slot name="icon" />
  </div>
  <div class="flex flex-col gap-2">
    <Heading as="h3" size="sm" align={align}>{title}</Heading>
    <Text muted class="leading-relaxed">{description}</Text>
  </div>
</div>
