---
import Text from '../atoms/Text.astro';

interface Props {
  question: string;
  answer: string;
  class?: string;
}

const { question, answer, class: className }: Props = Astro.props;
---

<details class={`rounded-lg bg-[var(--color-bg-muted)] p-6 ${className ?? ''}`}>
  <summary class="cursor-pointer font-semibold text-[var(--color-text)]">{question}</summary>
  <Text muted class="mt-3">{answer}</Text>
</details>
