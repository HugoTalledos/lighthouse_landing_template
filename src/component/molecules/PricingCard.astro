---
import Heading from '../atoms/Heading.astro';
import Text from '../atoms/Text.astro';

interface Props {
  name: string;
  price: string;
  period?: string;
  features: string[];
  ctaLabel: string;
  ctaHref?: string;
  featured?: boolean;
  badgeText?: string;
  class?: string;
}

const { name, price, period, features, ctaLabel, ctaHref, featured = false, badgeText, class: className }: Props = Astro.props;
---

<div
  class={`relative flex flex-col gap-6 rounded-2xl p-8 transition-transform duration-300 hover:z-10 hover:scale-105 hover:shadow-xl ${
    featured ? 'bg-[var(--color-text)] text-white' : 'bg-[var(--color-bg-muted)] text-[var(--color-text)]'
  } ${className ?? ''}`}
>
  {badgeText && (
    <span
      class={`inline-flex w-fit items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide ${
        featured ? 'border-white/30 text-white' : 'border-[var(--color-text)]/20 text-[var(--color-text)]'
      }`}
    >
      {badgeText}
    </span>
  )}

  <Heading as="h3" size="sm" class={featured ? 'text-white' : ''}>{name}</Heading>

  <div class={`border-t ${featured ? 'border-white/10' : 'border-black/10'}`} />

  <ul class="grid grid-cols-1 gap-x-6 gap-y-3 sm:grid-cols-2">
    {features.map((feature) => (
      <li class="flex items-center gap-2">
        <span
          class={`flex h-5 w-5 shrink-0 items-center justify-center rounded-full ${
            featured
              ? 'bg-white/10 text-white'
              : 'bg-[color-mix(in_srgb,var(--color-primary)_10%,white)] text-[var(--color-primary)]'
          }`}
        >
          <svg viewBox="0 0 20 20" fill="none" class="h-3 w-3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 10.5l3.5 3.5L16 6" />
          </svg>
        </span>
        <Text size="sm" class={featured ? 'text-white/90' : ''}>{feature}</Text>
      </li>
    ))}
  </ul>

  <div class={`mt-auto flex items-center justify-between gap-4 border-t pt-6 ${featured ? 'border-white/10' : 'border-black/10'}`}>
    <div class="flex shrink-0 flex-col">
      <span class="whitespace-nowrap text-3xl font-bold">{price}</span>
      {period && <span class={`text-xs font-normal ${featured ? 'text-white/60' : 'text-[var(--color-text-muted)]'}`}>{period}</span>}
    </div>
    <a
      href={ctaHref ?? '#formulario-captura'}
      class={`inline-flex min-w-0 items-center gap-2 rounded-full px-5 py-3 text-sm font-medium transition-opacity hover:opacity-90 ${
        featured ? 'bg-[var(--color-secondary)] text-[var(--color-text)]' : 'bg-[var(--color-text)] text-[var(--color-bg)]'
      }`}
    >
      <span class="min-w-0 truncate">{ctaLabel}</span>
      <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 10h12M11 5l5 5-5 5" />
      </svg>
    </a>
  </div>
</div>
